# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_ANON_KEY=<anon-key>

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── WhatsApp / Meta Business API ─────────────────────────────────────────────
WA_VERIFY_TOKEN=<any-random-string-you-choose>
WA_ACCESS_TOKEN=<meta-permanent-page-access-token>
WA_PHONE_NUMBER_ID=<whatsapp-business-phone-number-id>
WA_APP_SECRET=<meta-app-secret-for-hmac-verification>

# ── Resend (optional — email alerts for critical grievances) ─────────────────
RESEND_API_KEY=<your-resend-api-key>

# ── OpenAI (optional — Whisper for WhatsApp voice message transcription) ──────
# Without this, voice messages get a "not supported" reply to the citizen.
OPENAI_API_KEY=<your-openai-api-key>

# ── Mailgun (inbound email intake) ────────────────────────────────────────────
# Signing key: Mailgun dashboard → Webhooks → Webhook signing key
# Office ID: UUID of the office in Supabase that receives emailed grievances
MAILGUN_WEBHOOK_SIGNING_KEY=<mailgun-webhook-signing-key>
EMAIL_INTAKE_OFFICE_ID=<supabase-office-uuid>

# ── Twilio (inbound phone call AI + SMS ACK) ──────────────────────────────────
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_FROM_NUMBER=<your-twilio-e164-number>   # e.g. +12025551234 — used to send SMS ACKs
VOICE_FORWARD_NUMBER=<e164-number-for-human-transfer>
VOICE_OFFICE_ID=<supabase-office-uuid>
BASE_URL=<public-backend-url>                  # e.g. https://pollitymvp-production.up.railway.app

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | production
LOG_LEVEL=INFO
